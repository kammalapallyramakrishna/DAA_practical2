#include <iostream>
using namespace std;

int main() {
    int a[5] = {10, 20, 30, 40, 50};
    int key;

    cout << "Enter number to search: ";
    cin >> key;

    for (int i = 0; i < 5; i++) {
        if (a[i] == key) {
            cout << "Found at index " << i;
            return 0;
        }
    }

    cout << "error";
    return 0;
}
